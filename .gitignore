# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# MCP config (contains secrets)
.mcp.json

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# claude code personal settings
.claude/settings.local.json

# locally installed agent skills (npx skills) — personal, not team workflow
.agents/
.claude/skills/find-skills
# personal idea-capture skill: contains private Notion workspace IDs, not team workflow
.claude/skills/app-idee/

# typescript
*.tsbuildinfo
next-env.d.ts
docs/UI-INVENTORY.md

# IDE / editor config (personal, not app-relevant)
.idea/
.vscode/

# Firebase native config (contains project API keys; provide locally per environment)
android/app/google-services.json
ios/App/App/GoogleService-Info.plist

# App-Store-Screenshots aus dem Simulator (lokal generiert, nicht im Repo)
/Screenshots/
