{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/display/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/mellon-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|tone|size|ringColor|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, tone, size, ringColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|gold|blush|ink)$/]",
        "message": "<Avatar> tone must be one of 'green' | 'gold' | 'blush' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarStack'] > JSXAttribute > JSXIdentifier[name!=/^(?:people|size|max|ringColor|key|ref|className|style|children)$/]",
        "message": "<AvatarStack> doesn't accept that prop. Declared props: people, size, max, ringColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: role, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:admin|editor|observer|success|warning|error|neutral)$/]",
        "message": "<Badge> role must be one of 'admin' | 'editor' | 'observer' | 'success' | 'warning' | 'error' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|icon|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, icon, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalendarExportButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|fullWidth|onClick|key|ref|className|style|children)$/]",
        "message": "<CalendarExportButton> doesn't accept that prop. Declared props: state, fullWidth, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalendarExportButton'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:add|added|connect)$/]",
        "message": "<CalendarExportButton> state must be one of 'add' | 'added' | 'connect'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|interactive|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, interactive, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onClick|icon|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, onClick, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DateRangePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:range|status|onDark|key|ref|className|style|children)$/]",
        "message": "<DateRangePill> doesn't accept that prop. Declared props: range, status, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='DateRangePill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:zu_planen|in_planung|planung_abgeschlossen|abgeschlossen)$/]",
        "message": "<DateRangePill> status must be one of 'zu_planen' | 'in_planung' | 'planung_abgeschlossen' | 'abgeschlossen'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|helper|error|type|placeholder|value|onChange|multiline|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, helper, error, type, placeholder, value, onChange, multiline."
      },
      {
        "selector": "JSXOpeningElement[name.name='KanbanCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|cover|coverSrc|initiator|initiatorTone|range|progress|onClick|key|ref|className|style|children)$/]",
        "message": "<KanbanCard> doesn't accept that prop. Declared props: title, cover, coverSrc, initiator, initiatorTone, range, progress, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='KanbanCard'] > JSXAttribute[name.name='initiatorTone'] > Literal[value!=/^(?:green|gold|blush|ink)$/]",
        "message": "<KanbanCard> initiatorTone must be one of 'green' | 'gold' | 'blush' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|defaultValue|onChange|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, defaultValue, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:groupName|items|active|onChange|user|width|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: groupName, items, active, onChange, user, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|min|max|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, defaultValue, min, max, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|onChange|onFab|fabLabel|key|ref|className|style|children)$/]",
        "message": "<TabBar> doesn't accept that prop. Declared props: items, active, onChange, onFab, fabLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='VoteCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|cover|coverSrc|category|initiator|votes|needed|voted|defaultVoted|onVote|key|ref|className|style|children)$/]",
        "message": "<VoteCard> doesn't accept that prop. Declared props: title, cover, coverSrc, category, initiator, votes, needed, voted, defaultVoted, onVote."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
